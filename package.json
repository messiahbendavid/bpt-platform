{
  "name": "bpt-platform",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "pnpm --filter @bpt/shared build && pnpm --filter @bpt/web build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "worker": "pnpm --filter @bpt/worker dev",
    "api": "pnpm --filter @bpt/api dev",
    "web": "pnpm --filter @bpt/web dev",
    "db:migrate": "supabase db push",
    "db:seed": "supabase db seed"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
