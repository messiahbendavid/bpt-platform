# ── Polygon.io ──────────────────────────────────────────────
POLYGON_API_KEY=your_polygon_api_key_here
POLYGON_WS_URL=wss://socket.polygon.io/stocks

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Database (direct for migrations) ─────────────────────────
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ── Worker ───────────────────────────────────────────────────
WORKER_TICK_INTERVAL_MS=1000
WORKER_CORRELATION_INTERVAL_MS=900000
WORKER_HISTORICAL_LOOKBACK_DAYS=5
WORKER_MAX_SYMBOLS_PER_BATCH=50

# ── API Server ───────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
API_CORS_ORIGIN=http://localhost:5173

# ── Frontend (Vite — VITE_ prefix exposes to browser) ────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
VITE_API_BASE_URL=http://localhost:3001

# ── Scoring Weights ───────────────────────────────────────────
SMS_WEIGHT_STASIS_COUNT=0.40
SMS_WEIGHT_RISK_REWARD=0.30
SMS_WEIGHT_SIGNAL_STRENGTH=0.20
SMS_WEIGHT_DURATION=0.10

FMS_WEIGHT_NET_INCOME=0.30
FMS_WEIGHT_CASH_FLOWS=0.25
FMS_WEIGHT_REVENUE_TREND=0.30
FMS_WEIGHT_52W_PERCENTILE=0.15

CMS_WEIGHT_DECORR_MAGNITUDE=0.50
CMS_WEIGHT_DELTA_RATE=0.30
CMS_WEIGHT_DIRECTION_ALIGN=0.20

TMS_SMS_WEIGHT=1.0
TMS_FMS_WEIGHT=1.0
TMS_CMS_WEIGHT=1.0

# ── Runtime ───────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
